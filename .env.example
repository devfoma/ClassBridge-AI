# Root example env. See hub/.env.example for the hub-specific values.
# ClassBridge AI keeps everything on the local network. No cloud keys needed.

# --- Gemma / Ollama (used by the hub) ---
GEMMA_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434/api
OLLAMA_MODEL=gemma4

# --- Hub ---
PORT=4000
