{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node", "jest"]
  },
  "include": ["src/services/**/*.ts", "src/utils/**/*.ts", "src/types/**/*.ts", "src/__tests__/**/*.ts"]
}
