# ClassBridge AI Hub configuration

# Port the hub listens on. Students/teachers connect to http://<laptop-ip>:PORT
PORT=4000

# Where the SQLite database file lives (relative to hub/ or absolute)
DB_PATH=./data/classbridge.sqlite

# --- Gemma / AI provider ---
# GEMMA_PROVIDER = "ollama" (real Gemma) or "mock" (deterministic demo/test fallback)
GEMMA_PROVIDER=ollama

# Ollama local API base URL. Default final endpoint becomes http://localhost:11434/api/generate
OLLAMA_BASE_URL=http://localhost:11434/api

# Model name pulled into Ollama (e.g. `ollama pull gemma:2b` then set OLLAMA_MODEL=gemma:2b)
OLLAMA_MODEL=gemma4

# Request timeout for Gemma calls in milliseconds
OLLAMA_TIMEOUT_MS=60000

# If "true", when Ollama is unreachable the hub falls back to the deterministic mock
# provider instead of returning a 503. Handy for demos on machines without Ollama.
GEMMA_ALLOW_MOCK_FALLBACK=true
